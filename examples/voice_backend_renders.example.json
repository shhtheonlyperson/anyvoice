{
  "version": 1,
  "description": "Example manifest for registering externally rendered backend WAVs into the AnyVoice regression scorer.",
  "backends": [
    {
      "backend": "voxcpm2-hifi",
      "referenceAudio": "/path/to/ready-profile/reference.wav",
      "promptTextFile": "/path/to/ready-profile/reference-transcript.txt",
      "renders": [
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 1,
          "renderSeconds": 10.2,
          "outputWav": "/path/to/voxcpm2-hifi/zh_hant_polyphones-r01.wav"
        },
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 2,
          "renderSeconds": 10.1,
          "outputWav": "/path/to/voxcpm2-hifi/zh_hant_polyphones-r02.wav"
        },
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 3,
          "renderSeconds": 10.3,
          "outputWav": "/path/to/voxcpm2-hifi/zh_hant_polyphones-r03.wav"
        }
      ]
    },
    {
      "backend": "indextts2",
      "referenceAudio": "/path/to/ready-profile/reference.wav",
      "promptTextFile": "/path/to/ready-profile/reference-transcript.txt",
      "renders": [
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 1,
          "renderSeconds": 9.1,
          "outputWav": "/path/to/indextts2/zh_hant_polyphones-r01.wav",
          "metadataJson": {
            "engine": "IndexTTS2",
            "notes": "External render registered for AnyVoice scoring."
          }
        },
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 2,
          "renderSeconds": 9.2,
          "outputWav": "/path/to/indextts2/zh_hant_polyphones-r02.wav"
        },
        {
          "caseId": "zh_hant_polyphones",
          "repeat": 3,
          "renderSeconds": 9.0,
          "outputWav": "/path/to/indextts2/zh_hant_polyphones-r03.wav"
        }
      ]
    }
  ]
}
