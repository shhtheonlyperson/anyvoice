# Vercel should usually keep this disabled and call a separate GPU/local worker.
ANYVOICE_ENABLE_LOCAL_VOXCPM=0
ANYVOICE_STUB=1

# Vercel public API -> Mac Studio/local worker.
# Leave values blank in git; set real values in .env.local and Vercel env.
ANYVOICE_WORKER_URL=
ANYVOICE_WORKER_TOKEN=

# Local development example:
# ANYVOICE_ENABLE_LOCAL_VOXCPM=1
# ANYVOICE_STUB=0
# ANYVOICE_VOXCPM_PYTHON=/Users/shh/proj/brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

ANYVOICE_MODEL_ID=openbmb/VoxCPM2
ANYVOICE_MAX_UPLOAD_MB=80
ANYVOICE_RUNS_DIR=.anyvoice/runs
