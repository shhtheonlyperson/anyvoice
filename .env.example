# Vercel should usually keep this disabled and call a separate GPU/local worker.
ANYVOICE_ENABLE_LOCAL_VOXCPM=0
ANYVOICE_STUB=1

# Vercel public API -> Mac Studio/local worker.
# Leave values blank in git; set real values in .env.local and Vercel env.
ANYVOICE_WORKER_URL=
ANYVOICE_WORKER_TOKEN=

# Set to 1 only when running THIS server as the Mac Studio/local worker
# behind a Vercel proxy. When set, /api/local-worker/clone and
# /api/runs/:jobId/audio require Bearer ANYVOICE_WORKER_TOKEN.
# Leave unset for studio/dev mode — the audio route is then public so
# the browser can play its own generated clips without a token.
ANYVOICE_WORKER_MODE=

# Local development example:
# ANYVOICE_ENABLE_LOCAL_VOXCPM=1
# ANYVOICE_STUB=0
# ANYVOICE_VOXCPM_PYTHON=/Users/shh/proj/brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_ASR_PYTHON=/Users/shh/proj/brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_SPEAKER_PYTHON=/Users/shh/proj/brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_HOT_WORKER_URL=http://127.0.0.1:8765
# ANYVOICE_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

ANYVOICE_MODEL_ID=openbmb/VoxCPM2
# hifi = prompt_wav_path + prompt_text + reference_wav_path.
# prompt = older prompt-only path for rollback / A-B quality checks.
ANYVOICE_VOXCPM_CLONE_MODE=hifi
# Optional VoxCPM LoRA weights (.pth or directory containing lora_weights.ckpt)
# after a gated per-speaker profile has been trained.
ANYVOICE_VOXCPM_LORA_PATH=
ANYVOICE_MAX_UPLOAD_MB=80
ANYVOICE_RUNS_DIR=.anyvoice/runs
