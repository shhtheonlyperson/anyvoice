# Vercel should usually keep this disabled and call a separate GPU/local worker.
ANYVOICE_ENABLE_LOCAL_VOXCPM=0
ANYVOICE_STUB=1

# Vercel public API -> Mac Studio/local worker.
# Leave values blank in git; set real values in .env.local and Vercel env.
ANYVOICE_WORKER_URL=
ANYVOICE_WORKER_TOKEN=

# Set to 1 only when running THIS server as the Mac Studio/local worker
# behind a Vercel proxy. When set, /api/local-worker/clone and
# /api/runs/:jobId/audio require Bearer ANYVOICE_WORKER_TOKEN.
# Leave unset for studio/dev mode — the audio route is then public so
# the browser can play its own generated clips without a token.
ANYVOICE_WORKER_MODE=

# Local development example. When the *_PYTHON vars are unset, scripts
# auto-discover an interpreter: ./.venv-voxcpm, then a sibling
# ../brenda-voice/.venv-voxcpm checkout, then the system Python.
# ANYVOICE_ENABLE_LOCAL_VOXCPM=1
# ANYVOICE_STUB=0
# ANYVOICE_VOXCPM_PYTHON=../brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_ASR_PYTHON=../brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_SPEAKER_PYTHON=../brenda-voice/.venv-voxcpm/bin/python
# ANYVOICE_HOT_WORKER_URL=http://127.0.0.1:8765
# ANYVOICE_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

ANYVOICE_MODEL_ID=openbmb/VoxCPM2
# hifi = prompt_wav_path + prompt_text + reference_wav_path.
# prompt = older prompt-only path for rollback / A-B quality checks.
ANYVOICE_VOXCPM_CLONE_MODE=hifi
# Optional VoxCPM LoRA weights (.pth or directory containing lora_weights.ckpt)
# after a gated per-speaker profile has been trained.
ANYVOICE_VOXCPM_LORA_PATH=
# Optional product runtime renderer for an accepted non-VoxCPM profile backend.
# Reuses the backend shootout placeholders: {backend}, {target_text_file},
# {target_text}, {reference_audio}, {prompt_text_file}, {output_wav}, {seed}.
ANYVOICE_PROFILE_BACKEND_RENDER_COMMAND=
# preferred = use accepted external profile backend directly.
# voxcpm-first = try VoxCPM2 first, then fall back to accepted external backend.
ANYVOICE_PROFILE_BACKEND_MODE=preferred

# Backend shootout renderers. Prefer backend-specific commands so a mixed
# shootout can fill one backend without accidentally routing another backend to
# the wrong model.
ANYVOICE_BACKEND_RENDER_COMMAND=
ANYVOICE_BACKEND_RENDER_COMMAND_INDEXTTS2=
# Official F5-TTS CLI adapter. `uvx` keeps the runtime isolated and downloads
# SWivid/F5-TTS weights on first use.
# Example:
# ANYVOICE_BACKEND_RENDER_COMMAND_F5_TTS="python3 scripts/render_voice_backend_job.py --backend {backend} --case-id {case_id} --repeat {repeat} --text-file {target_text_file} --reference {reference_audio} --prompt {prompt_text_file} --text-prep-file {text_prep_file} --out {output_wav} --seed {seed}"
ANYVOICE_BACKEND_RENDER_COMMAND_F5_TTS=
ANYVOICE_F5_TTS_COMMAND="uvx --from f5-tts f5-tts_infer-cli"
ANYVOICE_F5_TTS_MODEL=F5TTS_v1_Base
ANYVOICE_F5_TTS_HF_MODEL=SWivid/F5-TTS
ANYVOICE_F5_TTS_DEVICE=mps
ANYVOICE_F5_TTS_NFE_STEP=16
ANYVOICE_F5_TTS_CFG_STRENGTH=2.0
ANYVOICE_F5_TTS_SPEED=1.0
ANYVOICE_F5_TTS_REMOVE_SILENCE=0
# Local MLX/TypelessMLX fallback candidate. It is not IndexTTS2 evidence.
# Example:
# ANYVOICE_BACKEND_RENDER_COMMAND_FISHAUDIO_S2_PRO="python3 scripts/render_voice_backend_job.py --backend {backend} --case-id {case_id} --repeat {repeat} --text-file {target_text_file} --reference {reference_audio} --prompt {prompt_text_file} --text-prep-file {text_prep_file} --out {output_wav} --seed {seed}"
ANYVOICE_BACKEND_RENDER_COMMAND_FISHAUDIO_S2_PRO=
ANYVOICE_MLX_AUDIO_TTS_GENERATE=
ANYVOICE_FISHAUDIO_S2_PRO_MODEL=fishaudio/s2-pro
ANYVOICE_MLX_AUDIO_STT_MODEL=
ANYVOICE_MLX_AUDIO_LANG_CODE=zh
ANYVOICE_MAX_UPLOAD_MB=80
ANYVOICE_RUNS_DIR=.anyvoice/runs
